# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/geu_alumni

# ─── App ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
PORT=3001
BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:8080

# ─── Email (SMTP) ───────────────────────────────────────────────────────────
# Used to deliver: signup-approval credentials, OTPs for password change,
# rejection notices. If left blank the server falls back to logging emails to
# the console — useful for local development. For Gmail use an *App Password*.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="GEU Alumni Connect <no-reply@geu-alumni.local>"
